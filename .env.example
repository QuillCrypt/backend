# Server Configuration
QC_MODE=0
QC_PORT=8080

# GitHub OAuth
QC_GH_CLIENTID=your_github_client_id
QC_GH_CLIENTSECRET=your_github_client_secret
QC_GH_CALLBACK=http://localhost:8080/auth/github/callback

# Google OAuth
QC_GOOGLE_CLIENTID=your_google_client_id
QC_GOOGLE_CLIENTSECRET=your_google_client_secret
QC_GOOGLE_CALLBACK=http://localhost:8080/auth/google/callback

# Redis Configuration
QC_REDISURL=redis://localhost:6379

# Postgres Configuration
QC_PGURL=postgres://user:password@localhost:5432/quillcrypt

